# Copy to .env and fill in your API keys

# Required — primary data source
FINANCIAL_DATASETS_API_KEY=your_key_here

# Required — financials fallback (foreign ADRs, non-Dec fiscal years) + /screen-stocks universe
FMP_API_KEY=your_key_here

# Optional — news fallback (when primary API returns no news)
FINNHUB_API_KEY=your_key_here

# Optional — force IPv4 DNS resolution (workaround for some networks)
# FINANCIAL_DATASETS_FORCE_IPV4=1
